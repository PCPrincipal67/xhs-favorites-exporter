{
  "manifest_version": 3,
  "name": "XHS Favorites Exporter",
  "version": "0.1.0",
  "description": "导出小红书收藏列表里的 note_id、xsec_token 和 URL。",
  "action": {
    "default_title": "XHS Favorites Exporter"
  },
  "host_permissions": [
    "https://www.xiaohongshu.com/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://www.xiaohongshu.com/*"
      ],
      "js": [
        "content-script.js"
      ],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "page-bridge.js"
      ],
      "matches": [
        "https://www.xiaohongshu.com/*"
      ]
    }
  ]
}
